{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Upload IASD",
  "version": "2.2.1",
  "identifier": "com.gabrielkramer.uploadiasddesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Upload IASD",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage"],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "whatsapp-bot.cjs"
    ],
    "category": "Utility",
    "shortDescription": "Sistema de upload para IASD",
    "longDescription": "Ferramenta para sonoplastas e técnicos de som receberem arquivos via upload, WhatsApp ou YouTube.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "bannerPath": "icons/icon.png",
        "dialogImagePath": "icons/icon.png",
        "language": "pt-BR"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    }
  }
}